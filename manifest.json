
{
  "manifest_version": 3,

  "name": "Enterprise Auto-Outreach & Form Automation Engine",

  "version": "2.0.0",

  "description": "Automated Outreach Engine with Smart Form Filling, Calendly Automation, Proxy Support and CAPTCHA Solver.",

  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "scripting",
    "proxy",
    "webRequest",
    "webRequestAuthProvider"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background/background.js"
  },

  "action": {
    "default_popup": "popup.html",
     "default_icon": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
  },

  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/contentScript.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "modules/*",
        "utils/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "icons": {
  "16": "icon16.png",
  "48": "icon48.png",
  "128": "icon128.png"
}
}